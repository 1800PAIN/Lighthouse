<title><%= siteLanguage[session.language || "en"].title %><% if (process.env.environment == "dev"){ %> (SANDBOX) <% } %></title>
<link rel="preload" href="/stylesheets/main.css" as="style">
<link rel="stylesheet" href="/stylesheets/main.css?v=<%= version %>">
<script src="/prism.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/2.1.3/jquery.min.js"></script>
<% var fontLink = "/stylesheets/" + session.font + ".css?v=1.6.1"; %>
    <link rel="stylesheet" href="<%= fontLink %>">
    <link rel="stylesheet" href="/stylesheets/iao-alert.css">
<script src="/iao-alert.jquery.js"></script>
<Script defer>
  // Hide content initially to prevent FOUC
let domReady = (cb) => {
  if (document.readyState === 'interactive' || document.readyState === 'complete') {
    cb();
  } else {
    document.addEventListener('DOMContentLoaded', cb);
  }
};

domReady(() => {

  // Load user's skin if applicable
  <% if ( typeof cookies.skin !== undefined || cookies.skin !== "lighthouse") { %>
    $("head").append(`<link rel="stylesheet" href="/stylesheets/<%= cookies.skin || "lighthouse" %>.css?v=<%= version %>">`);
  <% } else { %> 
    $("head").append(`<link rel="stylesheet" href="/stylesheets/lighthouse.css?v=<%= version %>">`);
  <% } %>

  // Set dark mode based on user preference or system setting
  const isDark = window.matchMedia("(prefers-color-scheme: dark)");
  const modeChoice = localStorage.getItem("lighthouse_mode") || (isDark.matches ? "dark" : "light");
  document.querySelector("html").setAttribute("data-theme", modeChoice);

  // Adjust text sizes if applicable
  <% if (cookies.textsize) { %>
    $("body").css("font-size", `${parseInt($("body").css("font-size")) * parseFloat(<%= cookies.textsize %>) || 1}px`);
  <% } %>


  <% 
    if (!session.system_term){
      session.system_term = "system";
    }
    if (!session.alter_term){
      session.alter_term = "alter";
    }
  
  %>
  // Replace bracketed terms
  if ($(".dyn")[0]){
        // Replace html
        $(".dyn").each(function(){
          
          $(this).html($(this).html()
          // Systems
          .replace(/\[\[SYSTEMCAP\]\]/g, "<%= capitalise(cookies.system_term || session.system_term || "system") %>")
          .replace(/\[\[SYSTEMS\]\]/g, "<%= pluralize(cookies.system_term || session.system_term || "system") %>")
          .replace(/\[\[SYSTEMSCAP\]\]/g, "<%= capitalise(pluralize(cookies.system_term || session.system_term || "system")) %>")
          .replace(/\[\[SYSTEM\]\]/g, "<%= cookies.system_term  || capitalise(session.system_term)|| "system" %>")
          // Subsystems
          .replace(/\[\[SUBSYSTEMCAP\]\]/g, "<%= capitalise(cookies.subsystem_term  || capitalise(session.subsystem_term)|| "subsystem") %>")
          .replace(/\[\[SUBSYSTEMS\]\]/g, "<%= pluralize(cookies.subsystem_term  || capitalise(session.subsystem_term)|| "subsystem") %>")
          .replace(/\[\[SUBSYSTEMSCAP\]\]/g, "<%= capitalise(pluralize(cookies.subsystem_term  || capitalise(session.subsystem_term)|| "subsystem")) %>")
          .replace(/\[\[SUBSYSTEM\]\]/g, "<%= cookies.subsystem_term || capitalise(session.subsystem_term) || "subsystem" %>")
          // Alters
          .replace(/\[\[ALTERCAP\]\]/g, "<%= capitalise(cookies.alter_term || session.alter_term || "alter") %>")
          .replace(/\[\[ALTERS\]\]/g, "<%= pluralize(cookies.alter_term || session.alter_term || "alter") %>")
          .replace(/\[\[ALTERSCAP\]\]/g, "<%= capitalise(pluralize(cookies.alter_term || session.alter_term || "alter")) %>")
          .replace(/\[\[ALTER\]\]/g, "<%= cookies.alter_term || session.alter_term || "alter" %>")
          // Other terms
          .replace(/\[\[PLURAL\]\]/g, "<%= cookies.plural_term || session.plural_term || "plural" %>")
        )
        $(this).prop('title', $(this).prop('title')
          // Systems
          .replace(/\[\[SYSTEMCAP\]\]/g, "<%= capitalise(cookies.system_term || session.system_term || "system") %>")
          .replace(/\[\[SYSTEMS\]\]/g, "<%= pluralize(cookies.system_term || session.system_term || "system") %>")
          .replace(/\[\[SYSTEMSCAP\]\]/g, "<%= capitalise(pluralize(cookies.system_term || session.system_term || "system")) %>")
          .replace(/\[\[SYSTEM\]\]/g, "<%= cookies.system_term  || capitalise(session.system_term)|| "system" %>")
          // Subsystems
          .replace(/\[\[SUBSYSTEMCAP\]\]/g, "<%= capitalise(cookies.subsystem_term  || capitalise(session.subsystem_term)|| "subsystem") %>")
          .replace(/\[\[SUBSYSTEMS\]\]/g, "<%= pluralize(cookies.subsystem_term  || capitalise(session.subsystem_term)|| "subsystem") %>")
          .replace(/\[\[SUBSYSTEMSCAP\]\]/g, "<%= capitalise(pluralize(cookies.subsystem_term  || capitalise(session.subsystem_term)|| "subsystem")) %>")
          .replace(/\[\[SUBSYSTEM\]\]/g, "<%= cookies.subsystem_term || capitalise(session.subsystem_term) || "subsystem" %>")
          // Alters
          .replace(/\[\[ALTERCAP\]\]/g, "<%= capitalise(cookies.alter_term || session.alter_term || "alter") %>")
          .replace(/\[\[ALTERS\]\]/g, "<%= pluralize(cookies.alter_term || session.alter_term || "alter") %>")
          .replace(/\[\[ALTERSCAP\]\]/g, "<%= capitalise(pluralize(cookies.alter_term || session.alter_term || "alter")) %>")
          .replace(/\[\[ALTER\]\]/g, "<%= cookies.alter_term || session.alter_term || "alter" %>")
          // Other terms
          .replace(/\[\[PLURAL\]\]/g, "<%= cookies.plural_term || session.plural_term || "plural" %>")
        )
        })
      }

  // Set language direction if applicable
  <% if (session.language == "ar") { %>
    document.documentElement.setAttribute('lang', 'AR');
    $("html").attr("dir", "rtl");
  <% } %>

  // Make content visible after all styles and modifications are applied
  document.body.style.visibility = 'visible';
});

</Script>
    
