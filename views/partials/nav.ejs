function toggleMode(){

  event.preventDefault();
  var $darkCss = $("link[href='/stylesheets/dark.css']");
  if ($darkCss.length) {
    $darkCss.remove();
  } else {
    $('head').append('<link type="text/css" rel="stylesheet" media="all" href="/stylesheets/dark.css">');
    $('body').find('*').each(function(){
    var color = window.getComputedStyle($(this).get(0), null).color;
    if ((color.toLowerCase() == "black") ||
        (color.toLowerCase() == "#000000") ||
        (color.toLowerCase() == "rgb(5,5,5)") ||
        (color.toLowerCase() == "rgb(0,0,0)")) {
            $(this).css("color", "ghostwhite");
    }    
});
  }
  // if ($('[name="mode"]').text() == "light_mode"){
