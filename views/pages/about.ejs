        <% var skinGroups=["Skip", "Misc. User Skins", "Galaxii Kingdom", "Constellation Collection", "Chaotic Troop", "Pax Vesania Collective", "Pride", "DivineChrysalism", "GOOPYGAMER9000", "Era vulgaris", "Skip"] %>
        <div id="wrapper">
            <% if (locals.messages.flash) { %>
