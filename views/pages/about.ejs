        <style>
           .skins {
            display: grid;
            grid-template-columns: repeat(3, 1fr); /* Defines 3 columns of equal width */
            grid-gap: 0.5em; /* Optional spacing between items */
            align-items: center;
            }

            .skins > li {
            list-style-type: none;
            text-align: center;
            max-width: 10em;
            padding: .5em;
            font-size: .85em;
            font-style: italic;
            }

            .skins > li > img{
                display: block;
                margin-left: auto;
  margin-right: auto;
            }
            .credits{
            -webkit-column-count: 3;
            -moz-column-count: 3;
            column-count: 3;
            }
            @media only screen and (max-width: 900px) {
                .credits{
            -webkit-column-count: 1;
            -moz-column-count: 1;
            column-count: 1;
            }
            }
        </style>
